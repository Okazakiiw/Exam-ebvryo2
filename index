            </div>

            <div id="review-details-section" class="hidden max-w-3xl mx-auto bg-white rounded-2xl shadow-sm border border-slate-200/60 p-6 animate-fadeIn">
                <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">ตรวจสอบประวัติการประเมินแบบข้อต่อข้อ (Itemized Logs)</h3>
                <div class="space-y-6" id="review-list-container"></div>
            </div>
        </section>

    </main>

    <script>
        const examDatabase = {
            formA: {
                title: "Part 1: CBD Embryology Mock Exam – Form A",
                description: "ชุดข้อสอบเน้นกลไกความผิดปกติแต่กำเนิด แฝดติดกัน และภาวะแทรกซ้อนทางรก (18 MCQs)",
                questions: [
                    {
                        text: "A male newborn has hypotonia, flat facial profile, upward-slanting palpebral fissures, protruding tongue, and sandal gap toes. Which karyotype is most likely?",
                        options: { A: "45,Χ", B: "47,ΧΥ,+13", C: "47,XY,+18", D: "46,XY,del(5p)", E: "47,ΧΥ,+21" },
                        correct: "E",
                        context: "ฟีโนไทป์ที่โจทย์ระบุ ได้แก่ กล้ามเนื้อปวกเปียก (hypotonia), ดั้งจมูกแบน, ตาเฉียงขึ้น, ลิ้นโตจุกปาก และช่องนิ้วเท้ากว้าง (sandal gap) เป็นลักษณะคลาสสิกของ Down syndrome (Trisomy 21)",
                        explanations: {
                            A: "ผิด: 45,X คือกลุ่มอาการ Turner syndrome พบเฉพาะในเพศหญิง และมีคอเป็นพังผืด (webbed neck)",
                            B: "ผิด: 47,XY,+13 คือ Patau syndrome จะพบลักษณะปากแหว่งเพดานโหว่รุนแรง รอยโรคที่หนังศีรษะ และนิ้วเกิน (polydactyly)",
                            C: "ผิด: 47,XY,+18 คือ Edwards syndrome สังเกตจากกำมือแน่นนิ้วเกยกัน (clenched fists) และเท้าปูดกลม (rocker-bottom feet)",
                            D: "ผิด: 46,XY,del(5p) คือ Cri-du-chat syndrome เด่นที่เสียงร้องแหลมคล้ายแมวจากการพัฒนาผิดปกติของกล่องเสียง",
                            E: "ถูกต้อง: 47,XY,+21 เป็นโครโมโซมคู่ที่ 21 เกินมา 1 แท่ง ซึ่งตรงกับกลุ่มอาการ Down syndrome ทุกประการ"
                        }
                    },
                    {
                        text: "A 45-year-old mother delivers a child with Down syndrome. What is the most common cytogenetic mechanism leading to this condition?",
                        options: { A: "Triploidy", B: "Maternal meiotic nondisjunction", C: "Paternal nondisjunction", D: "Microdeletion", E: "Uniparental disomy" },
                        correct: "B",
                        context: "อายุของมารดาที่มาก (Advanced Maternal Age) สัมพันธ์กับโอกาสเกิดความผิดพลาดในการแยกตัวของโครโมโซมคู่ที่ 21 ระหว่างกระบวนการสร้างเซลล์ไข่",
                        explanations: {
                            A: "ผิด: Triploidy หมายถึงมีโครโมโซมครบชุดเพิ่มเป็น 3 ชุด (69 แท่ง) มักแท้งตั้งแต่ไตรมาสแรก",
                            B: "ถูกต้อง: Maternal meiotic nondisjunction เป็นกลไกที่พบสูงถึง 90-95% ของเคส Down syndrome ทั้งหมด เนื่องจากกระบวนการไมโอซิสของไข่หยุดค้างเป็นเวลานานตามอายุขัยของมารดา",
                            C: "ผิด: Paternal nondisjunction (ความบกพร่องจากฝั่งพ่อ) พบได้เพียงประมาณ 5-10% เท่านั้น",
                            D: "ผิด: Microdeletion คือชิ้นส่วนเล็กๆ บนโครโมโซมขาดหายไป ไม่ได้ส่งผลให้จำนวนแท่งโครโมโซมเกิน",
                            E: "ผิด: Uniparental disomy คือการได้รับโครโมโซมทั้งคู่มาจากพ่อหรือแม่เพียงฝ่ายเดียว ไม่สัมพันธ์กับกลุ่มอาการโครโมโซมเกินแบบนี้"
                        }
                    },
                    {
                        text: "Which of the following prenatal tests provides a definitive fetal karyotype diagnosis rather than a screening risk calculation?",
                        options: { A: "Quad screen", B: "NIPT", C: "Nuchal translucency", D: "Amniocentesis", E: "PAPP-A" },
                        correct: "D",
                        context: "ต้องแยกแยะระหว่างการตรวจคัดกรองความเสี่ยง (Screening test) กับการตรวจเพื่อวินิจฉัยยืนยันโรค (Diagnostic test) ซึ่งต้องการตัวอย่างเซลล์จริงของทารก",
                        explanations: {
                            A: "ผิด: Quad screen เป็นการเจาะเลือดมารดาเพื่อตรวจฮอร์โมน 4 ชนิด นำมาคำนวณหาค่าสถิติความเสี่ยงเท่านั้น",
                            B: "ผิด: NIPT (Non-Invasive Prenatal Testing) ตรวจชิ้นส่วน cell-free DNA ของทารกในพลาสม่าแม่ มีความไวสูงมากแต่ยังจัดเป็น Screening test ไม่สามารถใช้วินิจฉัยขาดได้",
                            C: "ผิด: Nuchal translucency เป็นการอัลตราซาวด์วัดความหนาของของเหลวหลังคอทารก เพื่อหาความเสี่ยงร่วม",
                            D: "ถูกต้อง: Amniocentesis (การเจาะน้ำคร่ำ) เป็นกระบวนการ Invasive นำเซลล์ของทารกที่ปนอยู่ในน้ำคร่ำไปเพาะเลี้ยงเพื่อตรวจ Karyotype จริง จึงวินิจฉัยโรคโครโมโซมได้แน่นอน 100%",
                            E: "ผิด: PAPP-A เป็นโปรตีนในเลือดแม่ที่ใช้ตรวจคัดกรองร่วมในไตรมาสแรก"
                        }
                    },
                    {
                        text: "A pregnant woman has a snowstorm ultrasound pattern, no fetus identified, and very high beta-hCG. What is the diagnosis?",
                        options: { A: "Complete hydatidiform mole", B: "Ectopic pregnancy", C: "Placental abruption", D: "Partial mole", E: "Missed abortion" },
                        correct: "A",
                        context: "ภาพอัลตราซาวด์เห็นเป็นถุงน้ำขนาดเล็กกระจายตัวทั่วโพรงมดลูกคล้ายพายุหิมะ (Snowstorm pattern) ร่วมกับค่า beta-hCG ที่สูงเกินปกติอย่างรุนแรงเป็นลักษณะจำเพาะของครรรภ์ไข่ปลาอุก",
                        explanations: {
                            A: "ถูกต้อง: Complete hydatidiform mole (ครรภ์ไข่ปลาอุกชนิดสมบูรณ์) จะไม่มีส่วนของเนื้อเยื่อทารกหลงเหลืออยู่เลย และมีการเพิ่มจำนวนขนานใหญ่ของเนื้อเยื่อโทรโฟบลาสต์ส่งผลให้ฮอร์โมน beta-hCG พุ่งสูงมหาศาล",
                            B: "ผิด: Ectopic pregnancy (ท้องนอกมดลูก) จะตรวจพบถุงการตั้งครรภ์บริเวณปีกมดลูกหรือท่อนำไข่ ไม่ใช่พายุหิมะในมดลูก",
                            C: "ผิด: Placental abruption คือภาวะรกรอกตัวก่อนกำหนด มีเลือดออกรุนแรงและปวดท้อง มักเกิดในไตรมาส 3",
                            D: "ผิด: Partial mole (ชนิดบางส่วน) จะต้องเห็นชิ้นส่วนเนื้อเยื่อหรือโครงสร้างบางส่วนของตัวอ่อนทารกปรากฏอยู่ร่วมด้วย",
                            E: "ผิด: Missed abortion ตัวอ่อนทารกเสียชีวิตค้างในครรภ์ แต่โครงสร้างถุงการตั้งครรภ์ยังคงเห็นได้ชัดเจน"
                        }
                    },
                    {
                        text: "What is the primary genetic mechanism responsible for the development of a complete hydatidiform mole?",
                        options: { A: "An empty ovum fertilized with paternal duplication", B: "Maternal meiosis failure", C: "Primitive streak defect", D: "Dispermy of normal ovum", E: "Renal developmental mutation" },
                        correct: "A",
                        context: "ครรภ์ไข่ปลาอุกชนิดสมบูรณ์ (Complete Mole) มีลักษณะทางพันธุกรรมแบบสัญชาติพ่อล้วนๆ (Androgenetic) โดยไม่มีส่วนร่วมของสารพันธุกรรมจากฝ่ายแม่เลย",
                        explanations: {
                            A: "ถูกต้อง: เกิดจากไข่ที่ไม่มีนิวเคลียสหรือสารพันธุกรรมของแม่หลงเหลืออยู่ (Empty ovum) ถูกปฏิสนธิโดยอสุจิเดี่ยวที่มีโครโมโซม 23,X จากนั้นอสุจิทำการจำลองตัวเอง (Endoreduplication) เพิ่มโครโมโซมเป็น 46,XX ที่มาจากฝั่งพ่อล้วนๆ",
                            B: "ผิด: ความล้มเหลวของไมโอซิสฝั่งแม่นำไปสู่โรคกลุ่ม Aneuploidy ไม่เกี่ยวกับการสลายพันธุกรรมของไข่",
                            C: "ผิด: Primitive streak defect เกี่ยวข้องกับการเกิดความพิการกลางลำตัว หรือแฝดติดกัน ไม่ใช่ภาวะครรภ์ไข่ปลาอุก",
                            D: "ผิด: อสุจิสองตัวปฏิสนธิในไข่ปกติ (Dispermy) จะได้โครโมโซม 69 แท่ง (Triploidy) ซึ่งเป็นกลไกของ Partial mole",
                            E: "ผิด: ไม่มีความเกี่ยวข้องใดๆ กับยีนส์ระบบไต"
                        }
                    },
                    {
                        text: "Hyperthyroidism in molar pregnancy occurs because:",
