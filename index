                <div class="flex flex-col sm:flex-row justify-center gap-3">
                    <button onclick="toggleReviewDetails()" class="border border-slate-200 hover:bg-slate-50 text-slate-700 font-bold px-5 py-3 rounded-xl transition text-sm flex items-center justify-center">
