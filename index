                            E: "ผิด: เซลล์ Neural crest ไม่ควบคุมกระบวนการขยายตัวเชิงกลศาสตร์ของถุงลมปอดระยะนี้"
                        }
                    },
                    {
                        text: "Which best distinguishes malformation from deformation?",
                        options: { A: "Malformation is extrinsic; deformation is intrinsic", B: "Malformation occurs after birth; deformation occurs during gastrulation", C: "Malformation is an intrinsic developmental error; deformation is extrinsic mechanical distortion", D: "Both are caused only by chromosomal abnormalities", E: "Both have high recurrence risk" },
                        correct: "C",
                        context: "การแยกแยะต้นตอความพิการเชิงกลไก: ความบกพร่องภายในตัวอวัยวะเอง (Intrinsic) หรือแรงกระทำบดเบียดจากภายนอก (Extrinsic)",
                        explanations: {
                            A: "ผิด: สลับตำแหน่งกันอย่างสิ้นเชิง Malformation เป็นเรื่องของปัจจัยภายใน ส่วน Deformation เกิดจากแรงภายนอกมดลูก",
                            B: "ผิด: ทั้งสองภาวะเกิดขึ้นและก่อตัวสมบูรณ์ตั้งแต่ทารกอยู่ภายในครรภ์มารดา ไม่ใช่เกิดหลังคลอด",
                            C: "ถูกต้อง: **Malformation** มีสาเหตุมาจากความผิดปกติภายในตัวเนื้อเยื่ออวัยวะเองตั้งแต่จุดเริ่มต้นสร้าง พิมพ์เขียวยีนส์ผิดปกติ (**Intrinsic error**) ส่วน **Deformation** เกิดจากเนื้อเยื่อที่เดิมทีปกติสมบูรณ์ดี แต่ถูกแรงบีบเค้นบดเบียดเชิงกลศาสตร์ภายนอกมดลูกมาทำให้เสียรูปทรงกะทันหัน (**Extrinsic mechanical force**)",
                            D: "ผิด: Deformation ส่วนใหญ่เกิดจากปัจจัยทางกายภาพ เช่น ครรภ์แฝด มดลูกแคบ น้ำคร่ำน้อย ไม่ได้เกิดจากโครโมโซมผิดปกติเป็นหลัก",
                            E: "ผิด: Deformation มีอัตราการเกิดซ้ำในครรภ์ถัดไปต่ำมาก (Low recurrence risk) เพราะแก้ไขที่ตัวสิ่งแวดล้อมมดลูกแม่ได้ ต่างจากแผลยีนส์ของ Malformation"
                        }
                    },
                    {
                        text: "Which morphogen is strongly involved in brain and limb patterning?",
                        options: { A: "Insulin", B: "Sonic Hedgehog", C: "Hemoglobin", D: "Albumin", E: "Colligen type I" },
                        correct: "B",
                        context: "สารเคมีส่งสัญญาณกำหนดพิกัดและแกนสถาปัตยกรรมของร่างกายทารก (Morphogen gradient)",
                        explanations: {
                            A: "ผิด: อินซูลินคุมเมแทบอลิซึมระดับน้ำตาลและการเพิ่มมวลขนาดเซลล์ทั่วไป ไม่สร้างแผนผังพิกัดนิ้วมือและพูสมอง",
                            B: "ถูกต้อง: **Sonic Hedgehog (SHH)** เป็นมอร์โฟเจนหลักหลั่งมาจากกลุ่มเซลล์ Zone of Polarizing Activity (ZPA) ควบคุมการสร้างลายพิมพ์นิ้วมือจากนิ้วก้อยไปนิ้วโป้ง และหลั่งจาก Prechordal plate คุมการแยกซีกสมองซ้ายขวาอย่างจำเพาะเจาะจง",
                            C: "ผิด: ฮีโมโกลบินเป็นโปรตีนลำเลียงออกซิเจนในเม็ดเลือดแดง ไม่ทำหน้าที่ส่งสัญญาณเหนี่ยวนำโครงสร้างอวัยวะตัวอ่อน",
                            D: "ผิด: อัลบูมินรักษารอบความดันออสโมติกในพลาสม่าเลือด ไม่ควบคุมยีนส์พัฒนาการสร้างอวัยวะทารก",
                            E: "ผิด: คอลลาเจนชนิดที่ 1 เป็นโปรตีนโครงสร้างความเหนียวของผิวหนังและกระดูก ไม่ใช่โปรตีนส่งสัญญาณแบบสารมอร์โฟเจน"
                        }
                    },
                    {
                        text: "Adequate folic acid supplementation reduces risk of:",
                        options: { A: "Trisomy 21", B: "Neural tube defects", C: "Klinefelter syndrome", D: "Turner syndrome", E: "Robertsonian translocation" },
                        correct: "B",
                        context: "วิตามิน B9 (Folate) มีบทบาทสำคัญอย่างยิ่งต่อกระบวนการสังเคราะห์ DNA และกลไกปิดแนวท่อประสาทส่วนกลาง ",
                        explanations: {
                            A: "ผิด: กลุ่มอาการดาวน์เกิดจากความผิดพลาดในการแยกตัวของแท่งโครโมโซมระหว่างสร้างไข่ ไม่ลดอุบัติการณ์ด้วยการกินโฟลิก",
                            B: "ถูกต้อง: วิตามินโฟลิก (**Folic acid**) จำเป็นต่อกระบวนการแบ่งเซลล์อย่างรวดเร็วเพื่อม้วนปิดแผ่นประสาทให้กลายเป็นท่อประสาทสมบูรณ์ การกินโฟลิกเสริมก่อนตั้งครรภ์สามารถลดอัตราการเกิดภาวะความบกพร่องของท่อประสาทเปิด (**Neural tube defects** เช่น Spina bifida, Anencephaly) ได้สูงถึง 70%",
                            C: "ผิด: ไคลน์เฟลเตอร์เป็นความผิดปกติของจำนวนโครโมโซมเพศเกิน (47,XXY) โฟลิกป้องกันไม่ได้",
                            D: "ผิด: เทอร์เนอร์ซินโดรมเกิดจากโครโมโซมขาดหายเหลือแท่งเดียว (45,X) สัมพันธ์กับอุบัติเหตุสุ่มช่วงแบ่งเซลล์สืบพันธุ์",
                            E: "ผิด: Robertsonian translocation เป็นการแตกและเชื่อมสลับที่ของแท่งโครโมโซม ไม่มีความเชื่อมโยงกับระดับวิตามินโฟลิกในร่างกายแม่"
                        }
                    }
                ]
            }
        };

        // --- CORE EXECUTION LOGIC ---
        let activePartKey = null;
        let activeQuestionIndex = 0;
        let currentPartScore = 0;
        let runningTotalScore = 0;
        let trackingExamLogs = [];

        document.addEventListener("DOMContentLoaded", () => {
            buildDashboardGrid();
            refreshGlobalTallyScore();
        });

        function buildDashboardGrid() {
            const grid = document.getElementById("parts-grid");
            grid.innerHTML = "";

            Object.keys(examDatabase).forEach(key => {
                const module = examDatabase[key];
                const isFinished = localStorage.getItem(`status_${key}`) === "completed";
                const lastSavedScore = localStorage.getItem(`score_${key}`) || 0;

                const cardNode = document.createElement("div");
                cardNode.className = "bg-white rounded-2xl p-6 shadow-sm hover:shadow-md border border-slate-200/60 transition flex flex-col justify-between";
                cardNode.innerHTML = `
                    <div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[11px] font-bold px-2.5 py-1 rounded-md ${isFinished ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-amber-50 text-amber-700 border border-amber-200'}">
                                ${isFinished ? '✓ สำเร็จแล้ว' : '• รอดำเนินการ'}
                            </span>
                            <span class="text-xs font-bold text-slate-400">${module.questions.length} Questions</span>
                        </div>
                        <h3 class="text-base font-bold text-slate-800 mb-2">${module.title}</h3>
                        <p class="text-xs text-slate-500 mb-6 leading-relaxed">${module.description}</p>
                    </div>
                    <div class="flex items-center justify-between pt-4 border-t border-slate-100 mt-auto">
                        <span class="text-xs font-bold text-slate-500">
                            ${isFinished ? `คะแนนล่าสุด: <span class="text-blue-600">${lastSavedScore}/${module.questions.length}</span>` : ''}
                        </span>
                        <button onclick="launchExamArena('${key}')" class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs px-4 py-2.5 rounded-xl shadow-sm transition">
                            ${isFinished ? 'ทดสอบซ้ำอีกครั้ง' : 'เริ่มทำข้อสอบ'}
                        </button>
                    </div>
                `;
                grid.appendChild(cardNode);
            });
        }

        function refreshGlobalTallyScore() {
            let tally = 0;
            Object.keys(examDatabase).forEach(key => {
                tally += parseInt(localStorage.getItem(`score_${key}`) || 0);
            });
            runningTotalScore = tally;
            document.getElementById("global-score-tally").innerText = runningTotalScore;
        }

        function launchExamArena(partKey) {
            activePartKey = partKey;
            activeQuestionIndex = 0;
            currentPartScore = 0;
            trackingExamLogs = [];

            document.getElementById("dashboard-view").classList.add("hidden");
            document.getElementById("summary-view").classList.add("hidden");
            document.getElementById("quiz-view").classList.remove("hidden");

            displayTargetQuestion();
        }

        function displayTargetQuestion() {
            const module = examDatabase[activePartKey];
            const qData = module.questions[activeQuestionIndex];

            document.getElementById("explanation-panel").classList.add("hidden");
            document.getElementById("current-score").innerText = `${currentPartScore} ข้อ`;
            
            const pct = (activeQuestionIndex / module.questions.length) * 100;
            document.getElementById("progress-bar-fill").style.width = `${pct}%`;
            document.getElementById("progress-text").innerText = `ข้อที่ ${activeQuestionIndex + 1}/${module.questions.length}`;
            document.getElementById("question-text").innerText = qData.text;

            const box = document.getElementById("options-container");
            box.innerHTML = "";

            Object.keys(qData.options).forEach(key => {
                const choiceBtn = document.createElement("button");
                choiceBtn.id = `opt-${key}`;
                choiceBtn.onclick = () => verifyliveAnswer(key);
                choiceBtn.className = "w-full text-left p-4 rounded-xl border border-slate-200 hover:bg-slate-50 hover:border-slate-400 transition flex items-start space-x-3 group";
                choiceBtn.innerHTML = `
                    <span class="flex-shrink-0 w-6 h-6 rounded-md bg-slate-100 group-hover:bg-blue-100 text-slate-600 group-hover:text-blue-700 flex items-center justify-center font-bold text-xs transition">${key}</span>
                    <span class="text-slate-700 text-sm font-semibold pt-0.5">${qData.options[key]}</span>
                `;
                box.appendChild(choiceBtn);
            });
        }

        function verifyliveAnswer(selectedKey) {
            const module = examDatabase[activePartKey];
            const qData = module.questions[activeQuestionIndex];
            const listNodes = document.getElementById("options-container").children;

            for(let node of listNodes) { node.removeAttribute("onclick"); }

            const match = selectedKey === qData.correct;
            if(match) {
                currentPartScore++;
                const element = document.getElementById(`opt-${selectedKey}`);
                element.className = "w-full text-left p-4 rounded-xl border-2 border-emerald-500 bg-emerald-50/70 flex items-start space-x-3 transition";
                element.querySelector('span').className = "flex-shrink-0 w-6 h-6 rounded-md bg-emerald-500 text-white flex items-center justify-center font-bold text-xs";
            } else {
                const wrongElement = document.getElementById(`opt-${selectedKey}`);
                wrongElement.className = "w-full text-left p-4 rounded-xl border-2 border-red-500 bg-red-50/70 flex items-start space-x-3 transition";
                wrongTarget = wrongElement.querySelector('span').className = "flex-shrink-0 w-6 h-6 rounded-md bg-red-500 text-white flex items-center justify-center font-bold text-xs";
                
                const exactElement = document.getElementById(`opt-${qData.correct}`);
                exactElement.className = "w-full text-left p-4 rounded-xl border-2 border-emerald-500 bg-emerald-50/70 flex items-start space-x-3 transition";
                exactElement.querySelector('span').className = "flex-shrink-0 w-6 h-6 rounded-md bg-emerald-500 text-white flex items-center justify-center font-bold text-xs";
            }

            trackingExamLogs.push({
                title: qData.text,
                choices: qData.options,
                userAnswer: selectedKey,
                systemAnswer: qData.correct,
                status: match,
                rationale: qData.context
            });

            document.getElementById("clinical-context").innerText = qData.context;
            const itemizedBreakdown = document.getElementById("choice-breakdowns");
            itemizedBreakdown.innerHTML = "";

            Object.keys(qData.explanations).forEach(key => {
                const subNode = document.createElement("div");
                subNode.className = `p-3 rounded-xl text-xs leading-relaxed mb-1.5 border ${key === qData.correct ? 'bg-emerald-50 border-emerald-200 text-emerald-900 font-medium' : 'bg-white border-slate-200 text-slate-600'}`;
                subNode.innerHTML = `<strong>ช้อยส์ ${key}:</strong> ${qData.explanations[key]}`;
                itemizedBreakdown.appendChild(subNode);
            });

            document.getElementById("explanation-panel").classList.remove("hidden");
            document.getElementById("current-score").innerText = `${currentPartScore} ข้อ`;
        }

        function nextQuestion() {
            const module = examDatabase[activePartKey];
            activeQuestionIndex++;

            if(activeQuestionIndex < module.questions.length) {
                displayTargetQuestion();
            } else {
                buildPerformanceReport();
            }
        }

        function buildPerformanceReport() {
            const module = examDatabase[activePartKey];
            localStorage.setItem(`status_${activePartKey}`, "completed");
            localStorage.setItem(`score_${activePartKey}`, currentPartScore);

            document.getElementById("quiz-view").classList.add("hidden");
            document.getElementById("summary-view").classList.remove("hidden");
            document.getElementById("review-details-section").classList.add("hidden");

            document.getElementById("summary-score").innerText = currentPartScore;
            document.getElementById("summary-total").innerText = module.questions.length;

            const percentage = (currentPartScore / module.questions.length) * 100;
            const gradeContainer = document.getElementById("summary-grade");
            const iconContainer = document.getElementById("summary-icon-box");

            if(percentage >= 85) {
                gradeContainer.innerText = "ยอดเยี่ยม (Excellent)"; gradeContainer.className = "text-base font-extrabold mt-3 text-emerald-600";
                iconContainer.className = "inline-flex p-4 rounded-full bg-emerald-50 text-emerald-600 mb-4";
            } else if (percentage >= 70) {
                gradeContainer.innerText = "ดีมาก (Good)"; gradeContainer.className = "text-base font-extrabold mt-3 text-blue-600";
                iconContainer.className = "inline-flex p-4 rounded-full bg-blue-50 text-blue-600 mb-4";
            } else if (percentage >= 50) {
                gradeContainer.innerText = "ผ่านเกณฑ์พอใช้ (Pass)"; gradeContainer.className = "text-base font-extrabold mt-3 text-amber-600";
                iconContainer.className = "inline-flex p-4 rounded-full bg-amber-50 text-amber-600 mb-4";
            } else {
                gradeContainer.innerText = "ต้องทบทวนเพิ่ม (Needs Review)"; gradeContainer.className = "text-base font-extrabold mt-3 text-red-600";
                iconContainer.className = "inline-flex p-4 rounded-full bg-red-50 text-red-600 mb-4";
            }

            compileAccordionLogData();
            refreshGlobalTallyScore();
        }

        function toggleReviewDetails() {
            const block = document.getElementById("review-details-section");
            block.classList.toggle("hidden");
            if(!block.classList.contains("hidden")) {
                block.scrollIntoView({ behavior: 'smooth' });
            }
        }

        function compileAccordionLogData() {
            const logsBox = document.getElementById("review-list-container");
            logsBox.innerHTML = "";

            trackingExamLogs.forEach((item, idx) => {
                const wrapNode = document.createElement("div");
                wrapNode.className = "border border-slate-200 rounded-xl p-4 bg-slate-50/40";
                
                let rawChoices = "";
                Object.keys(item.choices).forEach(k => {
                    let styling = "border-slate-100 bg-white text-slate-700";
                    if(k === item.systemAnswer) styling = "border-emerald-300 bg-emerald-50 text-emerald-900 font-bold";
                    if(k === item.userAnswer && !item.status) styling = "border-red-300 bg-red-50 text-red-900";

                    rawChoices += `
                        <div class="text-xs p-2.5 rounded-lg border ${styling} mb-1 flex justify-between items-center">
                            <span><strong>${k}:</strong> ${item.choices[k]}</span>
                            ${k === item.systemAnswer ? '<span class="text-[10px] bg-emerald-500 text-white font-bold px-1.5 py-0.5 rounded">เฉลย</span>' : ''}
                            ${k === item.userAnswer && !item.status ? '<span class="text-[10px] bg-red-500 text-white font-bold px-1.5 py-0.5 rounded">คำตอบคุณ</span>' : ''}
                        </div>
                    `;
                });

                wrapNode.innerHTML = `
                    <div class="flex items-start space-x-2 mb-3">
                        <span class="flex-shrink-0 text-[10px] font-bold px-2 py-0.5 rounded ${item.status ? 'bg-emerald-500 text-white' : 'bg-red-500 text-white'}">
                            ข้อที่ ${idx + 1} • ${item.status ? 'ถูก' : 'ผิด'}
                        </span>
                        <h4 class="text-xs font-bold text-slate-800 leading-relaxed">${item.title}</h4>
                    </div>
                    <div class="space-y-1 mb-2">${rawChoices}</div>
                    <div class="bg-white p-3 rounded-lg border border-slate-200/80 text-xs text-slate-600 font-medium">
                        <span class="font-bold text-indigo-700 block mb-1">กลไกคลินิก:</span> ${item.rationale}
                    </div>
                `;
                logsBox.appendChild(wrapNode);
            });
        }

        function exitToDashboard() {
            document.getElementById("quiz-view").classList.add("hidden");
            document.getElementById("summary-view").classList.add("hidden");
            document.getElementById("dashboard-view").classList.remove("hidden");
            buildDashboardGrid();
        }

        function restartCurrentPart() {
            launchExamArena(activePartKey);
        }
    </script>
</body>
</html>
